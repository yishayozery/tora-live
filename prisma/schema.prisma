// TORA_LIVE — Prisma schema (PostgreSQL / Supabase)
// סנכרון מלא עם schema.prisma הנוכחי (SQLite) — לשימוש ב-production.
// כדי להחליף: cp prisma/schema.postgres.prisma prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------- Enums ----------
// ---------- משתמש בסיסי (auth) ----------
model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  role         String
  createdAt    DateTime   @default(now())

  rabbi        Rabbi?
  student      Student?
  organizedLessons Lesson[] @relation("LessonOrganizer")
}

// ---------- רב ----------
model Rabbi {
  id           String       @id @default(cuid())
  userId       String       @unique
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  slug         String       @unique
  name         String
  bio          String       @default("") @db.Text
  photoUrl     String?
  phone        String?
  status       String  @default("PENDING")
  isBlocked    Boolean      @default(false)
  profileCompleted Boolean  @default(false)

  calendarSync String?
  mediaLinks   String?

  liveMode     String     @default("OWN")
  streamKey    String?      @unique

  autoReplyEnabled Boolean  @default(false)
  autoReplyMessage String?  @db.Text

  categories   Category[]
  lessons      Lesson[]
  recurringTemplates RecurringLessonTemplate[]
  requests     ContactRequest[]
  followers    Follow[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

// ---------- תלמיד ----------
model Student {
  id            String         @id @default(cuid())
  userId        String         @unique
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  name          String
  isBlocked     Boolean        @default(false)
  blockedReason String?

  notifyChannel String  @default("EMAIL")
  phoneE164     String?

  createdAt     DateTime       @default(now())

  chatMessages    ChatMessage[]
  requests        ContactRequest[]
  follows         Follow[]
  bookmarks       Bookmark[]
  notifications   Notification[]
}

// ---------- קטגוריה ----------
model Category {
  id       String   @id @default(cuid())
  rabbiId  String
  rabbi    Rabbi    @relation(fields: [rabbiId], references: [id], onDelete: Cascade)
  name     String
  order    Int      @default(0)
  lessons  Lesson[]

  @@unique([rabbiId, name])
}

// ---------- שיעור ----------
model Lesson {
  id              String    @id @default(cuid())
  rabbiId         String?
  rabbi           Rabbi?    @relation(fields: [rabbiId], references: [id], onDelete: Cascade)
  organizerUserId String?
  organizer       User?     @relation("LessonOrganizer", fields: [organizerUserId], references: [id], onDelete: SetNull)
  organizerName   String?
  categoryId      String?
  category        Category? @relation(fields: [categoryId], references: [id])

  title           String
  description     String    @db.Text
  scheduledAt     DateTime
  durationMin     Int?
  locationName    String?
  locationUrl     String?
  isPublic        Boolean   @default(true)
  posterUrl       String?
  approvalStatus  String    @default("APPROVED")
  reportCount     Int       @default(0)
  isSuspended     Boolean   @default(false)
  language        String    @default("he")
  broadcastType   String    @default("LESSON")

  isRecurring     Boolean   @default(false)
  recurringRule   String?
  recurringGroupId String?
  // אם השיעור נוצר מ-template של שיעור קבוע
  templateId      String?
  template        RecurringLessonTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  // אם השיעור עודכן ידנית (שינוי חד-פעמי) — לא לדרוס בעדכון template
  manuallyEdited  Boolean   @default(false)

  youtubeUrl      String?
  spotifyUrl      String?
  applePodcastUrl String?
  soundcloudUrl   String?
  otherUrl        String?

  sourcesPdfUrl   String?
  transcriptText  String?   @db.Text

  isLive          Boolean   @default(false)
  liveMethod      String?
  streamId        String?
  playbackUrl     String?
  recordingUrl    String?
  recordingExpiry DateTime?
  liveEmbedUrl    String?

  viewCount       Int       @default(0)
  syncToCalendar  Boolean   @default(false)
  calendarEventId String?

  // --- Auto-discovery (lesson-scout) ---
  externalId      String?   @unique
  autoDiscovered  Boolean   @default(false)
  discoveredAt    DateTime?
  sourceId        String?
  source          RabbiSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  chatMessages    ChatMessage[]
  reports         Report[]
  bookmarks       Bookmark[]
  sources         LessonSource[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([rabbiId, scheduledAt])
  @@index([recurringGroupId])
  @@index([templateId])
}

// ---------- שיעור קבוע (תבנית) ----------
// תלמיד הרב מציין מה השעות לכל יום — המערכת יוצרת שיעורים אוטומטית.
// שבת + חגים מדולגים אוטומטית.
model RecurringLessonTemplate {
  id              String   @id @default(cuid())
  rabbiId         String
  rabbi           Rabbi    @relation(fields: [rabbiId], references: [id], onDelete: Cascade)

  title           String
  description     String   @default("")
  categoryId      String?
  language        String   @default("he")
  broadcastType   String   @default("LESSON")
  isPublic        Boolean  @default(true)

  // JSON: { sun: { enabled: true, time: "20:00", durationMin: 60 }, mon: {...}, ..., sat: { enabled: false } }
  schedule        String   // JSON.stringified

  startDate       DateTime
  endDate         DateTime // ברירת מחדל: startDate + 6 חודשים
  lastGeneratedUntil DateTime?
  lastHolidayWarningAt DateTime? // מתי נשלחה התראת חגים אחרונה (כדי לא לשלוח כפול תוך 7 ימים)

  status          String   @default("ACTIVE") // ACTIVE | PAUSED | CANCELLED

  lessons         Lesson[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([rabbiId, status])
}

// ---------- מקור PDF (Live Follow) ----------
model LessonSource {
  id            String   @id @default(cuid())
  lessonId      String
  lesson        Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  fileUrl       String
  fileName      String?
  currentPage   Int      @default(1)
  totalPages    Int?
  isLiveFollow  Boolean  @default(false)
  lastTouchedAt DateTime @updatedAt
  createdAt     DateTime @default(now())

  @@index([lessonId])
}

// ---------- עקיבה ----------
model Follow {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  rabbiId     String
  rabbi       Rabbi    @relation(fields: [rabbiId], references: [id], onDelete: Cascade)
  notifyOnNew Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@unique([studentId, rabbiId])
  @@index([rabbiId])
}

// ---------- סימון שיעור ללוח ----------
model Bookmark {
  id              String    @id @default(cuid())
  studentId       String
  student         Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  lessonId        String
  lesson          Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  remindBeforeMin Int       @default(30)
  reminderSentAt  DateTime?
  createdAt       DateTime  @default(now())

  @@unique([studentId, lessonId])
  @@index([reminderSentAt])
}

// ---------- התראות ----------
model Notification {
  id         String           @id @default(cuid())
  studentId  String
  student    Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  kind       String
  title      String
  body       String           @db.Text
  link       String
  readAt     DateTime?
  sentEmail  Boolean          @default(false)
  sentWa     Boolean          @default(false)
  createdAt  DateTime         @default(now())

  @@index([studentId, readAt])
}

// ---------- צ'אט שאלות ----------
model ChatMessage {
  id         String   @id @default(cuid())
  lessonId   String
  lesson     Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  studentId  String
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  content    String   @db.Text
  isAnswered Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([lessonId, createdAt])
}

// ---------- צור קשר עם הרב ----------
model ContactRequest {
  id            String        @id @default(cuid())
  rabbiId       String
  rabbi         Rabbi         @relation(fields: [rabbiId], references: [id], onDelete: Cascade)
  studentId     String
  student       Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  message       String        @db.Text
  reply         String?       @db.Text
  requestType   String?
  topic         String?
  requestedDate DateTime?
  requestedTime String?
  status        String @default("PENDING")
  // אם הפנייה אושרה — מזהה השיעור שנוצר. מאפשר לתלמיד לקפוץ ישירות אליו
  approvedLessonId String?
  createdAt     DateTime      @default(now())
  repliedAt     DateTime?
}

// ---------- חסות יומית ----------
model Sponsor {
  id             String         @id @default(cuid())
  date           DateTime       @db.Date
  name           String
  dedicationType String
  donorName      String?
  donorEmail     String?
  donationId     String?
  createdAt      DateTime       @default(now())

  @@index([date])
}

// ---------- תרומה ----------
model Donation {
  id              String          @id @default(cuid())
  amount          Int
  donorName       String
  donorEmail      String
  dedicationName  String?
  dedicationType  String?
  showPublicly    Boolean         @default(false)
  receiptSent     Boolean         @default(false)
  paymentRef      String?
  createdAt       DateTime        @default(now())
}

// ---------- הצעת שיעור ----------
model LessonSuggestion {
  id            String    @id @default(cuid())
  title         String
  description   String    @default("") @db.Text
  rabbiName     String?
  scheduledAt   DateTime?
  durationMin   Int?
  locationName  String?
  url           String    @db.Text
  posterUrl     String?   @db.Text
  broadcastType String    @default("LESSON")
  source        String
  sourceType    String
  rawContent    String?   @db.Text
  confidence    String    @default("MEDIUM")

  status        String    @default("PENDING")
  reviewedBy    String?
  reviewedAt    DateTime?
  rejectReason  String?
  approvedLessonId String?

  externalId    String?   @unique
  createdAt     DateTime  @default(now())

  @@index([status, createdAt])
  @@index([sourceType])
}

// ---------- מקור שיעורים חיצוני ----------
model RabbiSource {
  id              String    @id @default(cuid())
  rabbiId         String?
  platform        String
  channelId       String
  channelTitle    String
  channelUrl      String
  rabbiName       String?
  notes           String?
  lastCheckedAt   DateTime?
  lastFoundAt     DateTime?
  totalDiscovered Int       @default(0)
  enabled         Boolean   @default(true)
  trusted         Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  lessons         Lesson[]

  @@unique([platform, channelId])
  @@index([enabled, lastCheckedAt])
}

// ---------- מועמד למקור (לפני אישור) ----------
// מאוחסן כאן כדי שהאדמין יראה את כל המועמדים בממשק ויאשר אחד-אחד
model SourceCandidate {
  id                 String    @id @default(cuid())
  name               String    // שם הערוץ/הרב/הישיבה
  platform           String    @default("YOUTUBE")
  handle             String?   // @handle או channel/ID
  channelUrl         String?
  facebookUrl        String?
  category           String    // "yeshiva" | "rabbi" | "midrasha" | "org" | "facebook_only"
  priority           Int       @default(2)
  content            String?   // תיאור התוכן + הערות
  concerns           String?   // דגלים אדומים
  recommendedStatus  String    // "approve_trusted" | "approve_pending" | "verify" | "reject"
  reviewStatus       String    @default("PENDING") // "PENDING" | "APPROVED" | "REJECTED" | "DEFERRED"
  reviewNotes        String?
  approvedSourceId   String?   // אם אושר — איזה RabbiSource נוצר
  createdAt          DateTime  @default(now())
  reviewedAt         DateTime?

  @@index([reviewStatus, priority])
  @@index([category])
}

// ---------- דיווח ----------
model Report {
  id             String         @id @default(cuid())
  lessonId       String?
  lesson         Lesson?        @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  reporterEmail  String?
  category       String
  description    String         @db.Text
  status         String   @default("OPEN")
  createdAt      DateTime       @default(now())
}
