# --- אדמין ---
ADMIN_EMAIL=admin@tora-live.co.il

# --- DB (Supabase Postgres) ---
# Transaction pooler (port 6543) — for app queries
DATABASE_URL="postgresql://postgres.xxx:[email protected]:6543/postgres?pgbouncer=true"
# Session pooler (port 5432) — for migrations
DIRECT_URL="postgresql://postgres.xxx:[email protected]:5432/postgres"

# --- Auth ---
NEXTAUTH_SECRET=change-me-in-production
NEXTAUTH_URL=http://localhost:3000

# --- Google Calendar ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Microsoft Outlook ---
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# --- Cloudflare R2 ---
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=
CLOUDFLARE_R2_ENDPOINT=

# --- Cloudflare Stream (שידור חי + הקלטות) ---
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_STREAM_TOKEN=

# --- סליקה ---
TRANZILA_TERMINAL=
TRANZILA_SECRET=

# --- AI ---
OPENAI_API_KEY=

# --- Email (Resend) ---
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@tora-live.co.il
EMAIL_FROM_NAME=TORA_LIVE

# --- SMTP (חלופה ל-Resend) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@tora-live.co.il

# --- WhatsApp (Twilio / Meta Cloud API) ---
WHATSAPP_PROVIDER=twilio   # twilio | meta
WHATSAPP_TOKEN=
WHATSAPP_FROM=             # twilio: "whatsapp:+14155238886" | meta: phone number id

# --- Cron ---
CRON_SECRET=change-me      # נשלח כ-Authorization: Bearer ל-/api/cron/*
